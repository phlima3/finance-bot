datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TransactionType {
  EXPENSE
  INCOME
}

model Transaction {
  id          String          @id @default(uuid())
  amount      Float
  type        TransactionType
  category    String
  description String
  date        DateTime
  phone       String
  rawMessage  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([phone, category, date])
  @@index([date])
  @@index([type])
}
